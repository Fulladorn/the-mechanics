{
  "name": "the-mechanics",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Co-op survival puzzle game — repair a vehicle, drive it to safety.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
